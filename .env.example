# ============================================================
# LMS 테스트 환경 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요
# cp .env.example .env
# ============================================================

# LMS 사이트 URL
LMS_BASE_URL=https://swunivlms.gabia.io

# LMS 로그인 자격증명 (비워두면 실행 시 터미널에서 입력)
LMS_ADMIN_USERNAME=
LMS_ADMIN_PASSWORD=

# ============================================================
# LLM 제공자 설정
# LLM_PROVIDER: anthropic | openai | google
# 권장: anthropic (한국어 UI 인식 정확도 최고)
# ============================================================
LLM_PROVIDER=anthropic

# Claude (Anthropic) - https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# GPT (OpenAI) - https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Gemini (Google) - https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5-pro

# ============================================================
# 브라우저 설정
# ============================================================
# HEADLESS=true 이면 브라우저 창이 보이지 않음
HEADLESS=false
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=900

# ============================================================
# 타임아웃 설정 (밀리초)
# ============================================================
DOM_SETTLE_TIMEOUT=3000
NAV_TIMEOUT=30000

# Stagehand 로그 레벨 (0=없음, 1=정보, 2=디버그)
STAGEHAND_VERBOSE=1
